# Variables d'environnement pour le déploiement (Vercel, etc.)
# À configurer dans Vercel : Settings > Environment Variables

# URLs de votre backend PHP (hébergé en production)
# Exemple si votre API PHP est sur https://api.votredomaine.com :
PRESENTATION_API_URL=https://votredomaine.com/api/send-presentation.php
CONTACT_API_URL=https://votredomaine.com/api/send-contact.php
DOCUMENTATION_API_URL=https://votredomaine.com/api/send-documentation.php

# Optionnel : URL du formulaire (pour redirections)
NEXT_PUBLIC_PRESENTATION_FORM_URL=https://votredomaine.com/
